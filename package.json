{
  "name": "stride",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "test": "vitest",
    "test:ci": "vitest run --project=unit --coverage --reporter=junit --outputFile=test-report.junit.xml --reporter=default && vitest run --project=storybook --coverage --coverage.reportsDirectory=./coverage-storybook --reporter=junit --outputFile=test-report-storybook.junit.xml --reporter=default",
    "test:ui": "vitest --ui",
    "test:e2e": "npx playwright test",
    "test:e2e:coverage": "PLAYWRIGHT_COVERAGE=true npm run build && PLAYWRIGHT_COVERAGE=true npx playwright test && nyc report",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/roboto": "^5.2.10",
    "@mui/icons-material": "^9.0.0",
    "@mui/material": "^9.0.0",
    "@tanstack/react-query": "^5.100.7",
    "arktype": "^2.2.0",
    "axios": "^1.15.2",
    "chart.js": "^4.5.1",
    "chartjs-plugin-zoom": "^2.2.0",
    "framer-motion": "^12.38.0",
    "jszip": "^3.10.1",
    "konva": "^10.3.0",
    "leaflet": "^1.9.4",
    "luxon": "^3.7.2",
    "mapbox-gl": "^3.23.0",
    "ol": "^10.9.0",
    "react": "^19.2.3",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.5",
    "react-konva": "^19.2.3",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.14.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@chromatic-com/storybook": "^5.1.2",
    "@playwright/test": "^1.59.1",
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/addon-vitest": "^10.3.6",
    "@storybook/react": "^10.3.1",
    "@storybook/react-vite": "^10.3.6",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/leaflet": "^1.9.21",
    "@types/luxon": "^3.7.1",
    "@types/mapbox-gl": "^3.5.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser": "^4.1.5",
    "@vitest/browser-playwright": "^4.1.4",
    "@vitest/coverage-istanbul": "^4.1.2",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.4",
    "baseline-browser-mapping": "^2.10.24",
    "chromatic": "^16.6.3",
    "jsdom": "^29.1.1",
    "nyc": "^18.0.0",
    "playwright": "^1.59.1",
    "storybook": "^10.3.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vite-plugin-istanbul": "^8.0.0",
    "vitest": "^4.1.5",
    "vitest-browser-react": "^2.2.0"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ]
}
